+        "training_args",
+    )
+    outputs_raw = _require_mapping(
+        _require_field(top_level, "outputs", "root"),
+        "outputs",
+    )
+
+    split_sizes_raw = _require_mapping(
+        _require_field(synthetic_raw, "split_sizes", "synthetic"),
