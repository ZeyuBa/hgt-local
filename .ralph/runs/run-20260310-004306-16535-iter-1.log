+"""Typed runtime config loader for the alarm HGT pipeline."""
+
+from __future__ import annotations
+
+from dataclasses import dataclass
+from pathlib import Path
+from typing import Any
+
+import yaml
+
+from .config import AlarmHGTConfig
+from .synthetic import SyntheticGraphConfig
+from .trainer import LinkPredictionTrainerArgs
