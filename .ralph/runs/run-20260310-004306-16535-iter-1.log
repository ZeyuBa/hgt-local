+                "dataset_paths.test",
+            ),
+        ),
+        batching=BatchingSection(
+            per_device_train_batch_size=_require_int(
+                _require_field(batching_raw, "per_device_train_batch_size", "batching"),
+                "batching.per_device_train_batch_size",
