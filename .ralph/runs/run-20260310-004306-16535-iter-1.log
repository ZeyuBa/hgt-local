+                "synthetic.num_sites",
+                minimum=1,
+            ),
+            wl_stations_per_site=_require_int_or_range(
+                _require_field(synthetic_raw, "wl_stations_per_site", "synthetic"),
+                "synthetic.wl_stations_per_site",
+                minimum=1,
+            ),
+            fault_site_count=_require_int_or_range(
