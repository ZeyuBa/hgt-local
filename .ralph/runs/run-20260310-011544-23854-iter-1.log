+            raise ValueError(
+                f"{split_name} epoch {epoch} batch {batch_index} produced non-finite loss: "
+                f"{loss_value}"
+            )
+
+    def _finalize_epoch_loss(self, losses: list[float], *, split_name: str, epoch: int) -> float:
