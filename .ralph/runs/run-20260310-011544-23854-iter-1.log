+        max_width = max(array.shape[1] for array in arrays)
+        padded: list[np.ndarray] = []
+        for array in arrays:
+            pad_width = max_width - array.shape[1]
+            if pad_width:
+                array = np.pad(array, ((0, 0), (0, pad_width)), constant_values=fill_value)
+            padded.append(array)
+        return np.concatenate(padded, axis=0)
