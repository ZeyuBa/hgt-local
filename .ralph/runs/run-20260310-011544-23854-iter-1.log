+    history: list[dict[str, float | int]],
+) -> Path:
+    payload = {
+        "split": split,
+        "metric": metric_key,
+        "history": history,
+    }
+    history_path = Path(path)
+    history_path.write_text(
+        json.dumps(payload, indent=2, sort_keys=True) + "\n",
+        encoding="utf-8",
+    )
+    return history_path
