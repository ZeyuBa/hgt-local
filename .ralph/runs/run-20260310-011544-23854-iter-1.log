+    *,
+    split: str,
+    metric_key: str,
+    history: list[dict[str, float | int]],
+) -> Path:
+    payload = {
+        "split": split,
+        "metric": metric_key,
+        "history": history,
+    }
+    history_path = Path(path)
+    history_path.write_text(
