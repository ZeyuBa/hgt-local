+        if key not in payload or not math.isfinite(float(payload[key]))
+    ]
+    if missing_or_invalid:
+        missing = ", ".join(missing_or_invalid)
+        raise ValueError(f"missing required test metrics: {missing}")
+    return _write_json(path, payload)
