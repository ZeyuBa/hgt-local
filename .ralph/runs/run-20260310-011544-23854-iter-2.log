+def _checkpoint_payload(
+    *,
+    run_mode: str,
+    model_state_dict: dict[str, Any],
+    epoch: int | None = None,
+    val_loss: float | None = None,
+) -> dict[str, Any]:
+    return {
+        "run_mode": run_mode,
+        "epoch": epoch,
+        "val_loss": val_loss,
+        "model_state_dict": model_state_dict,
+    }
