+def save_checkpoints(
+    runtime: RuntimeObjects,
+    *,
+    run_mode: str,
+    best_epoch: int | None,
+    best_val_loss: float | None,
+    best_model_state: dict[str, Any] | None,
+) -> CheckpointArtifacts:
