+            model_state_dict=best_model_state,
+            epoch=best_epoch,
+            val_loss=best_val_loss,
+        ),
+        best_checkpoint_path,
+    )
+    return CheckpointArtifacts(
+        last_checkpoint_path=last_checkpoint_path,
+        best_checkpoint_path=best_checkpoint_path,
+    )
