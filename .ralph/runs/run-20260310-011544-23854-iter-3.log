+            )
+            if is_trainable and not alarm_entity_id.startswith("ne_is_disconnected;")
+        ]
+        if leaked_alarm_ids:
+            raise ValueError(
+                "model design drift: non-trainable alarms leaked into trainable_mask "
+                f"in {split_name} sample {sample['sample_id']}: {leaked_alarm_ids[:3]}"
+            )
+
+
