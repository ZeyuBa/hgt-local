import json
import tempfile
from pathlib import Path
import numpy as np
import torch
from sklearn.metrics import f1_score, precision_score, recall_score
from alarm_hgt.synthetic import generate_sample
from alarm_hgt.runtime_config import load_runtime_config
from alarm_hgt.train import resolve_runtime_paths, prepare_runtime_environment, build_runtime_objects, save_checkpoints

base = Path('configs/alarm_hgt.yaml').read_text()
config = load_runtime_config('configs/alarm_hgt.yaml')

def write_samples(path, seeds):
    path.parent.mkdir(parents=True, exist_ok=True)
    with path.open('w', encoding='utf-8') as handle:
        for seed in seeds:
            handle.write(json.dumps(generate_sample(seed=seed, config=config.synthetic.to_generation_config()), ensure_ascii=True) + '\\n')

split = {'train': [18,19,39,58,63,65,7,8,9,10,11,12], 'val': [96,13,14,15], 'test': [106,16,17,20]}
for epochs in (8,10,12):
    tmpdir = Path(tempfile.mkdtemp(prefix='us006-quick4-'))
    config_text = base.replace('data/synthetic', str(tmpdir / 'data'))
    config_text = config_text.replace('outputs/checkpoints', str(tmpdir / 'checkpoints'))
    config_text = config_text.replace('outputs/results', str(tmpdir / 'results'))
    config_text = config_text.replace('    train: 12\\n    val: 4\\n    test: 4\\n', '    train: 12\\n    val: 4\\n    test: 4\\n', 1)
    config_text = config_text.replace('  num_train_epochs: 8\\n', f'  num_train_epochs: {epochs}\\n', 1)
    config_path = tmpdir / 'config.yaml'
    config_path.write_text(config_text, encoding='utf-8')
    cfg = load_runtime_config(config_path)
    paths = resolve_runtime_paths(cfg)
    prepare_runtime_environment(paths)
    for split_name in ('train','val','test'):
        write_samples(paths.dataset_paths[split_name], split[split_name])
    runtime = build_runtime_objects(cfg, paths)
    result = runtime.trainer.train_and_validate(num_epochs=cfg.training_args.num_train_epochs, learning_rate=cfg.training_args.learning_rate, weight_decay=cfg.training_args.weight_decay, results_dir=paths.results_dir)
    ckpts = save_checkpoints(runtime, run_mode='smoke', best_epoch=result.best_epoch, best_val_loss=result.best_val_loss, best_model_state=result.best_model_state)
    checkpoint = torch.load(ckpts.best_checkpoint_path, map_location='cpu')
    runtime.model.load_state_dict(checkpoint['model_state_dict'])
    def collect(split_name):
        dataset = runtime.datasets[split_name]
        loader = runtime.trainer.get_test_dataloader(dataset) if split_name == 'test' else runtime.trainer.get_eval_dataloader(dataset)
        probs=[]; labels=[]
        for batch in loader:
            out = runtime.model(**batch)
            mask = batch['trainable_mask']
            probs.extend(torch.sigmoid(out.logits)[mask].detach().cpu().tolist())
            labels.extend(batch['labels'][mask].detach().cpu().tolist())
        return np.array(probs), np.array(labels, dtype=int)
    val_probs, val_labels = collect('val')
    test_probs, test_labels = collect('test')
    threshold = 0.0
    best_val_f1 = -1.0
    for candidate in np.linspace(0.0, 1.0, 101):
        score = f1_score(val_labels, val_probs >= candidate, zero_division=0)
        if score > best_val_f1:
            best_val_f1 = score
            threshold = float(candidate)
    preds = test_probs >= threshold
    print(epochs, {'threshold': threshold, 'val_f1': best_val_f1, 'test_f1': f1_score(test_labels, preds, zero_division=0), 'precision': precision_score(test_labels, preds, zero_division=0), 'recall': recall_score(test_labels, preds, zero_division=0)})
