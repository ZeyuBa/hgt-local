import json
import torch
from alarm_hgt.runtime_config import load_runtime_config
from alarm_hgt.train import resolve_runtime_paths, build_runtime_objects
config = load_runtime_config('configs/alarm_hgt.yaml')
paths = resolve_runtime_paths(config)
runtime = build_runtime_objects(config, paths)
ckpt = torch.load(paths.checkpoints_dir / 'smoke-best.pt', map_location='cpu')
runtime.model.load_state_dict(ckpt['model_state_dict'])
result = runtime.trainer.evaluate(runtime.datasets['test'], split_name='test', epoch=ckpt.get('epoch') or config.training_args.num_train_epochs)
print(json.dumps(result.metrics, indent=2, sort_keys=True))
loader = runtime.trainer.get_test_dataloader(runtime.datasets['test'])
probs = []
labels = []
for batch in loader:
    out = runtime.model(**batch)
    mask = batch['trainable_mask']
    p = torch.sigmoid(out.logits)[mask]
    y = batch['labels'][mask]
    probs.extend(float(v) for v in p)
    labels.extend(int(v.item()) for v in y)
print('count', len(probs), 'min', min(probs), 'max', max(probs), 'mean', sum(probs) / len(probs))
print('top20', sorted(zip(probs, labels), reverse=True)[:20])
