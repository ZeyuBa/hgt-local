            result = runtime.trainer.train_and_validate(num_epochs=epochs, learning_rate=lr, weight_decay=config.training_args.weight_decay, results_dir=paths.results_dir)
            ckpts = save_checkpoints(runtime, run_mode='smoke', best_epoch=result.best_epoch, best_val_loss=result.best_val_loss, best_model_state=result.best_model_state)
            test = evaluate_test_split(runtime, checkpoint_path=ckpts.best_checkpoint_path)
            improved = 0
            for idx in range(1, len(result.train_history)):
                improved += int((result.train_history[idx]['train_loss'] < result.train_history[idx-1]['train_loss']) or (result.val_history[idx]['val_loss'] < result.val_history[idx-1]['val_loss']))
