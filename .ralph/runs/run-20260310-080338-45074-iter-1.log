+    threshold = float(validation_result.metrics.get("edge_best_threshold", 0.5))
+    if threshold < 0.0 or threshold > 1.0:
+        raise ValueError(f"validation threshold must be within [0.0, 1.0], got {threshold}")
+    return threshold
