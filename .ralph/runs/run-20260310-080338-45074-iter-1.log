import json
import tempfile
from pathlib import Path
import torch
import torch.nn.functional as F
import alarm_hgt.modeling as modeling
from alarm_hgt.synthetic import generate_sample
from alarm_hgt.runtime_config import load_runtime_config
from alarm_hgt.train import resolve_runtime_paths, prepare_runtime_environment, build_runtime_objects, save_checkpoints, evaluate_test_split

base = Path('configs/alarm_hgt.yaml').read_text()

def write_samples(path, seeds):
    path.parent.mkdir(parents=True, exist_ok=True)
    with path.open('w', encoding='utf-8') as handle:
        for seed in seeds:
            handle.write(json.dumps(generate_sample(seed=seed), ensure_ascii=True) + '\\n')

def weighted_loss(logits, labels, mask):
    active_logits = logits[mask]
    active_labels = labels[mask]
    if active_labels.numel() == 0:
        return logits.sum() * 0.0
    positives = active_labels.sum()
    negatives = active_labels.numel() - positives
    if positives.item() > 0:
        pos_weight = torch.tensor(float(negatives / positives), device=logits.device, dtype=logits.dtype)
        return F.binary_cross_entropy_with_logits(active_logits, active_labels, pos_weight=pos_weight)
    return F.binary_cross_entropy_with_logits(active_logits, active_labels)

modeling.masked_bce_loss = weighted_loss

