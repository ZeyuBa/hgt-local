import json
import tempfile
from pathlib import Path
from alarm_hgt.runtime_config import load_runtime_config
from alarm_hgt.train import run_pipeline

base = Path('configs/alarm_hgt.yaml').read_text()
# small search over synthetic seeds and epoch counts
candidates = []
for synthetic_seed in range(1, 21):
    for epochs in (3, 5):
        tmpdir = Path(tempfile.mkdtemp(prefix='us006-search-'))
        config_text = base.replace('seed: 7\\n', f'seed: {synthetic_seed}\\n', 1)
        config_text = config_text.replace('num_train_epochs: 3\\n', f'num_train_epochs: {epochs}\\n', 1)
        config_text = config_text.replace('data/synthetic', str(tmpdir / 'data'))
        config_text = config_text.replace('outputs/checkpoints', str(tmpdir / 'checkpoints'))
        config_text = config_text.replace('outputs/results', str(tmpdir / 'results'))
        config_path = tmpdir / 'config.yaml'
        config_path.write_text(config_text, encoding='utf-8')
        try:
            run_pipeline(config_path, 'smoke')
            metrics = json.loads((tmpdir / 'results' / 'test_metrics.json').read_text())
            train = json.loads((tmpdir / 'results' / 'train_history.json').read_text())['history']
            val = json.loads((tmpdir / 'results' / 'val_history.json').read_text())['history']
            improved = 0
            for idx in range(1, len(train)):
                train_improved = train[idx]['train_loss'] < train[idx - 1]['train_loss']
                val_improved = val[idx]['val_loss'] < val[idx - 1]['val_loss']
                improved += int(train_improved or val_improved)
            candidates.append({
                'synthetic_seed': synthetic_seed,
                'epochs': epochs,
                'f1': metrics['f1'],
                'best_f1': metrics['edge_best_f1'],
                'improved': improved,
                'transitions': max(len(train) - 1, 0),
            })
        except Exception as exc:
            candidates.append({
                'synthetic_seed': synthetic_seed,
                'epochs': epochs,
                'error': str(exc),
            })
print(json.dumps(sorted(candidates, key=lambda item: (item.get('f1', -1), item.get('best_f1', -1))), indent=2))
