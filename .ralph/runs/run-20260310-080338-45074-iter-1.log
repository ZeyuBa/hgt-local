+def _calibrate_validation_threshold(
+    runtime: RuntimeObjects,
+    *,
+    checkpoint_path: Path,
+) -> float:
+    validation_result = _evaluate_checkpoint_split(
+        runtime,
+        checkpoint_path=checkpoint_path,
+        split_name="val",
