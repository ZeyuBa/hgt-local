base = Path('configs/alarm_hgt.yaml').read_text()

def write_samples(path, seeds):
    path.parent.mkdir(parents=True, exist_ok=True)
    with path.open('w', encoding='utf-8') as handle:
        for seed in seeds:
            handle.write(json.dumps(generate_sample(seed=seed), ensure_ascii=True) + '\\n')

def weighted_loss(logits, labels, mask):
    active_logits = logits[mask]
    active_labels = labels[mask]
    if active_labels.numel() == 0:
        return logits.sum() * 0.0
    positives = active_labels.sum()
    negatives = active_labels.numel() - positives
    if positives.item() > 0:
        pos_weight = torch.tensor(float(negatives / positives), device=logits.device, dtype=logits.dtype)
        return F.binary_cross_entropy_with_logits(active_logits, active_labels, pos_weight=pos_weight)
    return F.binary_cross_entropy_with_logits(active_logits, active_labels)

modeling.masked_bce_loss = weighted_loss
split = {
    'train': [18,19,39,58,7,8,9,10],
    'val': [63,11,12,13],
    'test': [65,14,15,16],
}
for epochs in (8,10,12):
    tmpdir = Path(tempfile.mkdtemp(prefix='us006-8split-'))
    config_text = base.replace('data/synthetic', str(tmpdir / 'data'))
    config_text = config_text.replace('outputs/checkpoints', str(tmpdir / 'checkpoints'))
    config_text = config_text.replace('outputs/results', str(tmpdir / 'results'))
    config_text = config_text.replace('  num_train_epochs: 3\\n', f'  num_train_epochs: {epochs}\\n', 1)
    config_text = config_text.replace('  learning_rate: 0.0005\\n', '  learning_rate: 0.001\\n', 1)
    config_path = tmpdir / 'config.yaml'
    config_path.write_text(config_text, encoding='utf-8')
    config = load_runtime_config(config_path)
    paths = resolve_runtime_paths(config)
    prepare_runtime_environment(paths)
    for split_name in ('train','val','test'):
        write_samples(paths.dataset_paths[split_name], split[split_name])
    runtime = build_runtime_objects(config, paths)
    result = runtime.trainer.train_and_validate(num_epochs=epochs, learning_rate=0.001, weight_decay=config.training_args.weight_decay, results_dir=paths.results_dir)
    ckpts = save_checkpoints(runtime, run_mode='smoke', best_epoch=result.best_epoch, best_val_loss=result.best_val_loss, best_model_state=result.best_model_state)
    checkpoint = torch.load(ckpts.best_checkpoint_path, map_location='cpu')
    runtime.model.load_state_dict(checkpoint['model_state_dict'])
    def collect(split_name):
        dataset = runtime.datasets[split_name]
        loader = runtime.trainer.get_test_dataloader(dataset) if split_name == 'test' else runtime.trainer.get_eval_dataloader(dataset)
        probs=[]; labels=[]
        for batch in loader:
            out = runtime.model(**batch)
            mask = batch['trainable_mask']
            probs.extend(torch.sigmoid(out.logits)[mask].detach().cpu().tolist())
            labels.extend(batch['labels'][mask].detach().cpu().tolist())
        return np.array(probs), np.array(labels, dtype=int)
    val_probs, val_labels = collect('val')
    test_probs, test_labels = collect('test')
    best_threshold = 0.0
    best_val_f1 = -1.0
    for threshold in np.linspace(0.0, 1.0, 101):
        score = f1_score(val_labels, val_probs >= threshold, zero_division=0)
        if score > best_val_f1:
            best_val_f1 = score
            best_threshold = float(threshold)
    preds = test_probs >= best_threshold
    improved = sum(int((result.train_history[i]['train_loss'] < result.train_history[i-1]['train_loss']) or (result.val_history[i]['val_loss'] < result.val_history[i-1]['val_loss'])) for i in range(1, len(result.train_history)))
    print({'epochs': epochs, 'val_threshold': best_threshold, 'val_f1': best_val_f1, 'test_f1': f1_score(test_labels, preds, zero_division=0), 'precision': precision_score(test_labels, preds, zero_division=0), 'recall': recall_score(test_labels, preds, zero_division=0), 'improved': improved, 'transitions': len(result.train_history)-1})
