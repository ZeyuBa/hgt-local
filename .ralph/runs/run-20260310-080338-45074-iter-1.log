+    targets = {
+        "train": min(train_size, max(1, train_size // 2)) if train_size > 0 else 0,
+        "val": 1 if int(split_sizes.get("val", 0)) > 0 else 0,
+        "test": 1 if int(split_sizes.get("test", 0)) > 0 else 0,
