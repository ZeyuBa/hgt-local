+            raise ValueError(f"run summary test metric {key} does not match saved test metrics")
+
+    if run_mode == "smoke":
+        _enforce_smoke_acceptance(
+            train_history,
+            val_history,
+            test_metrics=test_metrics,
+        )
+
+    return {
