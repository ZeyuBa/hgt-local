+
+    if run_mode == "smoke":
+        _enforce_smoke_acceptance(
+            train_history,
+            val_history,
+            test_metrics=test_metrics,
+        )
+
+    return {
+        **result_paths,
+        **checkpoint_paths,
+    }
+
+
